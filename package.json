{
  "name": "@redentor_dev/pi-goal",
  "version": "0.1.2",
  "type": "module",
  "description": "Minimal goal tracking and auto-continuation for pi: start a goal, resume it, check progress.",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "goal"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/redentordev/pi-goal.git"
  },
  "bugs": {
    "url": "https://github.com/redentordev/pi-goal/issues"
  },
  "homepage": "https://github.com/redentordev/pi-goal#readme",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "pack:check": "npm pack --dry-run"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "@types/node": "^24.0.0",
    "typebox": "^1.3.3",
    "typescript": "^5.9.0"
  },
  "files": [
    "extensions",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
